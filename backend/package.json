{
  "name": "edutryout-backend",
  "type": "module",
  "scripts": {
    "dev": "node --import tsx src/dev.ts",
    "build": "bunx prisma generate && bunx tsc --noEmit",
    "start": "node --import tsx src/dev.ts",
    "prisma:generate": "bunx prisma generate",
    "prisma:migrate": "bunx prisma migrate dev",
    "prisma:deploy": "bunx prisma migrate deploy",
    "seed": "bun run src/seed/seed.ts",
    "seed:questions": "bun run src/seed/seed-questions.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.6",
    "@neondatabase/serverless": "^1.1.0",
    "@prisma/adapter-neon": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@supabase/supabase-js": "^2.110.1",
    "dotenv": "^17.4.2",
    "hono": "^4.12.28",
    "ws": "^8.18.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^26.1.0",
    "@types/ws": "^8.18.1",
    "prisma": "^7.8.0",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3"
  }
}
