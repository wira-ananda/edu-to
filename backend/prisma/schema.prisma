generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  STUDENT
}

enum DifficultyLevel {
  LOW
  MEDIUM
  HIGH
}

enum WeightPriority {
  LOW
  NORMAL
  HIGH
  VERY_HIGH
}

enum SessionStatus {
  ONGOING
  FINISHED
}

enum AnswerOption {
  A
  B
  C
  D
}

model User {
  id             String   @id @default(cuid())
  supabaseUserId String   @unique
  name           String
  email          String   @unique
  role           Role     @default(STUDENT)
  school         String?
  className      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  sessions TryoutSession[]
}

model Subject {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  questions Question[]
  tryouts   Tryout[]
}

model Question {
  id            String       @id @default(cuid())
  subjectId     String
  questionText  String
  optionA       String
  optionB       String
  optionC       String
  optionD       String
  correctAnswer AnswerOption

  difficultyLevel    DifficultyLevel
  difficultyScore    Int
  detectedIndicators Json

  weightPriority WeightPriority @default(NORMAL)
  weight         Int            @default(3)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  answers Answers[]
  wrsLogs WrsLog[]

  @@index([subjectId])
  @@index([difficultyLevel])
  @@index([subjectId, difficultyLevel])
}

model Tryout {
  id              String   @id @default(cuid())
  subjectId       String
  title           String
  totalQuestions  Int
  durationMinutes Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  subject  Subject         @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  sessions TryoutSession[]
}

model TryoutSession {
  id             String          @id @default(cuid())
  userId         String
  tryoutId       String
  initialLevel   DifficultyLevel
  currentLevel   DifficultyLevel
  totalQuestions Int
  score          Int             @default(0)
  correctCount   Int             @default(0)
  wrongCount     Int             @default(0)
  status         SessionStatus   @default(ONGOING)
  startedAt      DateTime        @default(now())
  finishedAt     DateTime?

  user    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tryout  Tryout    @relation(fields: [tryoutId], references: [id], onDelete: Cascade)
  answers Answers[]
  wrsLogs WrsLog[]
}

model Answers {
  id             String       @id @default(cuid())
  sessionId      String
  questionId     String
  selectedAnswer AnswerOption?
  isCorrect      Boolean
  answeredAt     DateTime     @default(now())

  session  TryoutSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  question Question      @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, questionId])
}

model WrsLog {
  id                         String          @id @default(cuid())
  sessionId                  String
  questionId                 String
  currentLevel               DifficultyLevel
  candidateCount             Int
  totalWeight                Int
  randomValue                Int
  selectedQuestionWeight     Int
  selectedQuestionDifficulty DifficultyLevel
  createdAt                  DateTime        @default(now())

  session  TryoutSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  question Question      @relation(fields: [questionId], references: [id], onDelete: Cascade)
}
