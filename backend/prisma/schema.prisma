generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  TEACHER
  STUDENT
}

enum DifficultyLevel {
  LOW
  MEDIUM
  HIGH
}

enum WeightPriority {
  LOW
  NORMAL
  HIGH
  VERY_HIGH
}

enum SessionStatus {
  ONGOING
  FINISHED
}

enum AnswerOption {
  A
  B
  C
  D
}

enum TryoutStatus {
  DRAFT
  OPEN
  CLOSED
}

model User {
  id             String   @id @default(cuid())
  supabaseUserId String   @unique
  name           String
  email          String   @unique
  role           Role     @default(STUDENT)
  school         String?
  className      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  sessions TryoutSession[]

  ownedSubjects  Subject[]  @relation("SubjectOwner")
  ownedQuestions Question[] @relation("QuestionOwner")
  ownedTryouts   Tryout[]   @relation("TryoutOwner")

  @@index([role])
}

model Subject {
  id      String  @id @default(cuid())
  name    String
  ownerId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner User? @relation("SubjectOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  questions Question[]
  tryouts   Tryout[]

  @@unique([ownerId, name])
  @@index([ownerId])
  @@index([name])
}

model Question {
  id        String  @id @default(cuid())
  subjectId String
  ownerId   String?

  questionText  String
  optionA       String
  optionB       String
  optionC       String
  optionD       String
  correctAnswer AnswerOption

  imageUrl     String?
  imagePath    String?
  imageAltText String?

  difficultyLevel    DifficultyLevel
  difficultyScore    Int
  detectedIndicators Json

  weightPriority WeightPriority @default(NORMAL)
  weight         Int            @default(3)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  owner   User?   @relation("QuestionOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  answers Answers[]
  wrsLogs WrsLog[]

  @@index([subjectId])
  @@index([ownerId])
  @@index([difficultyLevel])
  @@index([subjectId, difficultyLevel])
  @@index([weightPriority])
}

model Tryout {
  id        String  @id @default(cuid())
  subjectId String
  ownerId   String?

  title           String
  totalQuestions  Int
  durationMinutes Int

  // 1 = one attempt only
  // 2 or more = limited attempts
  // null = unlimited attempts until owner closes the tryout
  maxAttempts Int? @default(1)

  status TryoutStatus @default(OPEN)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  owner   User?   @relation("TryoutOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  sessions TryoutSession[]

  @@index([subjectId])
  @@index([ownerId])
  @@index([status])
}

model TryoutSession {
  id       String @id @default(cuid())
  userId   String
  tryoutId String

  attemptNumber Int @default(1)

  initialLevel   DifficultyLevel
  currentLevel   DifficultyLevel
  totalQuestions Int
  score          Int             @default(0)
  correctCount   Int             @default(0)
  wrongCount     Int             @default(0)
  status         SessionStatus   @default(ONGOING)
  startedAt      DateTime        @default(now())
  finishedAt     DateTime?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tryout Tryout @relation(fields: [tryoutId], references: [id], onDelete: Cascade)

  answers Answers[]
  wrsLogs WrsLog[]

  @@index([userId])
  @@index([tryoutId])
  @@index([status])
  @@index([userId, tryoutId])
  @@index([userId, tryoutId, attemptNumber])
}

model Answers {
  id             String        @id @default(cuid())
  sessionId      String
  questionId     String
  selectedAnswer AnswerOption?
  isCorrect      Boolean
  answeredAt     DateTime      @default(now())

  session  TryoutSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  question Question      @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, questionId])
  @@index([sessionId])
  @@index([questionId])
}

model WrsLog {
  id                         String          @id @default(cuid())
  sessionId                  String
  questionId                 String
  currentLevel               DifficultyLevel
  candidateCount             Int
  totalWeight                Int
  randomValue                Int
  selectedQuestionWeight     Int
  selectedQuestionDifficulty DifficultyLevel
  createdAt                  DateTime        @default(now())

  session  TryoutSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  question Question      @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([questionId])
}
