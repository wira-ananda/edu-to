{
  "name": "edutryout",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "bun --filter '*' dev",
    "dev:frontend": "bun --filter frontend dev",
    "dev:backend": "bun --filter backend dev",
    "db:generate": "bun --filter backend db:generate",
    "db:migrate": "bun --filter backend db:migrate"
  }
}
