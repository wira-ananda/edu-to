cat > .gitignore <<'EOF'
# Dependencies
node_modules/

# Bun
bun-debug.log*
bun-error.log*

# Environment files
.env
.env.*
!.env.example

frontend/.env
frontend/.env.*
!frontend/.env.example

backend/.env
backend/.env.*
!backend/.env.example

# SvelteKit
frontend/.svelte-kit/
frontend/build/
frontend/.vite/
frontend/.vercel/
frontend/.netlify/

# Backend build output
backend/dist/
backend/build/

# Prisma
# Do not ignore prisma/schema.prisma
# Do not ignore prisma/migrations
generated/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS files
.DS_Store
Thumbs.db

# Editor
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/

# Test coverage
coverage/

# Misc
.cache/
.temp/
.tmp/
EOF

.env
.env.*
backend/.env
backend/.env.*
frontend/.env
frontend/.env.*

!backend/.env.example
!frontend/.env.example